                    "saml",
                    "sso"
                  ],
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "query": [
                    {
                      "key": "SAMLRequest",
                      "value": "<string>"
                    },
                    {
                      "key": "RelayState",
                      "value": "<string>"
                    },
                    {
                      "key": "SigAlg",
                      "value": "http://www.w3.org/2001/04/xmldsig-more#rsa-sha256"
