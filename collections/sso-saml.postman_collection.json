          "name": "Get SAML Metadata",
          "request": {
            "name": "Get SAML Metadata",
            "description": {
              "content": "Returns the SAML 2.0 metadata XML document for this identity provider or service provider. The metadata document contains entity ID, SSO binding endpoints, certificate for signature verification, and supported NameID formats required for federation configuration.",
              "type": "text/plain"
