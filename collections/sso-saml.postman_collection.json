                        "content": "(Required) Base64-encoded SAML Response XML document containing the authentication assertion signed by the IdP.",
                        "type": "text/plain"
                      },
                      "key": "SAMLResponse",
                      "value": "<string>"
                    },
                    {
                      "disabled": false,
                      "description": {
                        "content": "Opaque value originally sent in the AuthnRequest and returned unchanged by the IdP.",
                        "type": "text/plain"
                      },
                      "key": "RelayState",
                      "value": "<string>"
                    }
