      "name": "Logout",
      "description": {
        "content": "SAML 2.0 Single Logout (SLO) endpoints for terminating SSO sessions across all service providers.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "5c9c2e1f-08ae-4123-887f-691f716d0cb7",
          "name": "Initiate SAML Single Logout",
          "request": {
            "name": "Initiate SAML Single Logout",
            "description": {
              "content": "Initiates a SAML 2.0 Single Logout (SLO) flow via HTTP Redirect Binding. Sends a LogoutRequest to the identity provider to terminate the SSO session. The IdP propagates the logout to all other service providers in the SSO session.",
              "type": "text/plain"
            },
